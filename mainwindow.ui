           <property name="styleSheet">
            <string notr="true">QPushButton {
    background-color: transparent;
    color: #D1E7D1;
    border: none;
    border-radius: 10px;
    padding: 10px 16px;
    margin: 2px 6px;
    text-align: left;
    font-size: 14px;
    font-weight: 500;
}

QPushButton:hover {
    background-color: #181818;
    color: #F5F5F5;
}

QPushButton:pressed {
    background-color: #242424;
}

QPushButton:checked {
    background-color: #0B3D0B;
    color: #F5F5F5;
    border-left: 4px solid #4F9F4F;
}

QPushButton:checked:hover {
    background-color: #155315;
}

QPushButton:disabled {
    color: #5A5A5A;
}

QPushButton:focus {
    outline: none;
}</string>
